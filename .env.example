# ============================================
# BuilderAI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- AI Providers ---

# Primary: Google Gemini Flash
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Fallback: DeepSeek-V3
DEEPSEEK_API_KEY=sk-...

# Groq (optional)
# GROQ_API_KEY=gsk_...

# Force provider selection (optional): 'gemini' | 'deepseek'
# If unset, auto-selects based on available API keys (Gemini first)
# AI_PROVIDER=gemini

# --- Frontend Model Availability Flags ---
# These NEXT_PUBLIC_ flags tell the browser which models are usable.
# Set to "1" for each provider whose API key is configured above.
# Required: without these the model selector shows all models as "unconfigured".
NEXT_PUBLIC_GEMINI_CONFIGURED=    # set to 1 if GOOGLE_GENERATIVE_AI_API_KEY is set
NEXT_PUBLIC_DEEPSEEK_CONFIGURED=  # set to 1 if DEEPSEEK_API_KEY is set
NEXT_PUBLIC_GROQ_CONFIGURED=      # set to 1 if GROQ_API_KEY is set

# --- Database ---

# Local development (Docker PostgreSQL):
#   1. Start: docker compose up -d
#   2. Use the URLs below as-is — no changes needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/builder_ai
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/builder_ai

# Production (Supabase PostgreSQL) — replace the lines above with:
#   DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres

# --- Supabase Public Keys ---
# Only required for production (Sandpack-generated apps write to Supabase directly).
# Leave blank for local development.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Auth ---

# GitHub OAuth (optional if Guest-only mode is sufficient)
GITHUB_ID=Ov23li...
GITHUB_SECRET=abc123...

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- API ---

# Base URL for frontend API calls (empty for local dev, set to Vercel domain in production)
# Example: https://builder-ai.vercel.app
NEXT_PUBLIC_API_URL=

# --- Vercel Deploy API (for one-click deployment) ---

VERCEL_TOKEN=your_vercel_api_token
VERCEL_TEAM_ID=

# Cron job secret — set in Vercel Environment Variables
# Used to authenticate /api/cron/cleanup-guests
CRON_SECRET=
